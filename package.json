{
  "name": "corretiza-app",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "test": "docker-compose up postgres -d && cd backend && venv\\Scripts\\activate && pytest tests/ -v",
    "predev": "node setup-env.js",
    "dev": "docker-compose up --build",
    "stop": "docker-compose down",
    "prebuild": "node setup-env.js",
    "build": "docker-compose -f docker-compose.yml build",
    "start": "docker-compose -f docker-compose.yml up -d",
    "stop:prod": "docker-compose -f docker-compose.yml down",
    "clean": "docker system prune -af --volumes"
  }
}