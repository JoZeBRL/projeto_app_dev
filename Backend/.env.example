# Ambiente: development ou production
ENV=

# JWT - Chave secreta para assinar os tokens (use uma chave longa e aleatória em produção)
SECRET_KEY=
ALGORITHM=HS256
# Tempo de expiração do access token em minutos (ex: 1440 = 24h). Vazio = nunca expira
ACCESS_TOKEN_EXPIRE_MINUTES=
# Tempo de expiração do refresh token em dias (ex: 30 = 30 dias). Vazio = nunca expira
REFRESH_TOKEN_EXPIRE_DAYS=

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@HOST_DO_BANCO:5432/POSTGRES_DB

# pgAdmin
PGADMIN_EMAIL=
PGADMIN_PASSWORD=

# URL do frontend (https://app.corretiza.com.br)
FRONTEND_URL=